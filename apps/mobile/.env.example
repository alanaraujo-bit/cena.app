# Base URL of the CENA API as reachable FROM THE DEVICE.
# - iOS simulator:      http://localhost:3333
# - Android emulator:   http://10.0.2.2:3333
# - Physical device:    http://<your-machine-LAN-IP>:3333  (e.g. http://192.168.0.10:3333)
EXPO_PUBLIC_API_URL=

# RevenueCat public SDK keys (from the RevenueCat dashboard, one per store).
# Only work inside a custom EAS dev client/build — react-native-purchases has
# no effect in Expo Go, so premium purchases stay disabled there by design.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
