# --- Core ---
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
CORS_ORIGIN=*

# --- Auth (JWT) ---
# Generate strong values in production, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=180d

# --- Database (Postgres) — wired in a later milestone ---
DATABASE_URL=postgresql://user:password@localhost:5432/cena?schema=public

# --- TMDB (canonical catalog source) ---
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=

# --- Object storage (S3-compatible, e.g. Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- RevenueCat (server-side entitlement webhook) ---
REVENUECAT_WEBHOOK_SECRET=
