// CENA — Prisma schema.
// Model names are in English for a consistent codebase convention; the domain
// vocabulary (ranks, watch states) is preserved via enums/values.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

enum PrivacyMode {
  publico
  apenas_amigos
  privado
}

enum CinephileLevel {
  iniciante
  intermediario
  avancado
  especialista
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  bio          String?

  // Gamification.
  activeFrameId String?
  activeFrame   Frame?  @relation("ActiveFrame", fields: [activeFrameId], references: [id], onDelete: SetNull)

  privacyMode PrivacyMode @default(publico)

  // Premium (RevenueCat). Cached/derived from Subscription + webhook events —
  // never the source of truth by itself (see subscriptionService).
  entitlement       EntitlementTier @default(free)
  premiumExpiresAt  DateTime?
  subscription      Subscription?
  revenueCatEvents  RevenueCatEvent[]

  onboarding   OnboardingCompletion?
  refreshTokens RefreshToken[]
  watchEntries WatchEntry[]
  favorites    FavoriteTitle[]
  activities   Activity[]
  likes        Like[]
  comments     Comment[]
  following    Follow[] @relation("Following")
  followers    Follow[] @relation("Followers")
  cinephileOrder  CinephileOrder?
  rankingEvents   RankingEvent[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsCaused  Notification[] @relation("NotificationActor")
  pushTokens   PushToken[]
  ownedFrames   UserFrame[] @relation("FrameOwner")
  giftedFrames  UserFrame[] @relation("FrameGiftedBy")
  versusCreated Versus[]
  versusVotes   VersusVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastActiveAt DateTime @default(now())

  @@index([email])
  @@index([username])
}

/// One row per issued refresh token (rotation): logging out or refreshing
/// revokes the old row. A stolen-then-rotated token is detectable because its
/// row is already revoked. See §5.1.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 of the raw token — never store the token itself.
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  /// The token that replaced this one (rotation chain), for reuse detection.
  replacedByHash String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Onboarding
// ---------------------------------------------------------------------------

model OnboardingCompletion {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Self-rated level — a cold-start signal, not a locked label.
  level          CinephileLevel?
  /// TMDB genre ids selected as favorites.
  favoriteGenres Int[]           @default([])

  notificationsPrimed Boolean @default(false)
  seededTitles        Boolean @default(false)
  followedFounder     Boolean @default(false)

  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Catalog + personal tracking
// ---------------------------------------------------------------------------

enum MediaType {
  movie
  tv
}

/// Three explicit, parallel watch states — never inferred from other fields.
enum WatchState {
  assistido
  assistindo
  para_assistir
}

/// Cached TMDB metadata. Also the CinephileContentMetadata source for the ICG
/// calculation (genres/countries/decade/popularity/runtime/director), so we
/// never recompute it per request. Refreshed opportunistically on detail view.
model Title {
  id        String    @id @default(cuid())
  /// Stable cross-system key: "movie-603".
  key       String    @unique
  tmdbId    Int
  mediaType MediaType

  title          String
  year           Int?
  overview       String  @default("")
  posterUrl      String?
  backdropUrl    String?
  voteAverage    Float   @default(0)
  popularity     Float   @default(0)
  runtimeMinutes Int?
  genreIds       Int[]   @default([])
  countries      String[] @default([])
  director       String?

  watchEntries WatchEntry[]
  favoritedBy  FavoriteTitle[]
  activities   Activity[]
  versusAsA    Versus[] @relation("VersusTitleA")
  versusAsB    Versus[] @relation("VersusTitleB")

  cachedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tmdbId, mediaType])
}

/// A user's relationship to a title. One row per (user, title); the `state`
/// enum is explicit, and rating/watchedAt attach to a watched entry.
model WatchEntry {
  id      String     @id @default(cuid())
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId String
  title   Title      @relation(fields: [titleId], references: [id], onDelete: Cascade)

  state     WatchState
  rating    Float?
  watchedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, titleId])
  @@index([userId, state])
  @@index([titleId])
}

/// A small, explicitly ordered shelf of favorite titles shown on the profile —
/// distinct from watched history (brief §5.3).
model FavoriteTitle {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId String
  title   Title  @relation(fields: [titleId], references: [id], onDelete: Cascade)

  /// Ascending display order; new favorites append at the end.
  order Int

  createdAt DateTime @default(now())

  @@unique([userId, titleId])
  @@index([userId, order])
}

// ---------------------------------------------------------------------------
// Social layer
// ---------------------------------------------------------------------------

enum FollowStatus {
  pending
  accepted
}

/// Directed follow edge. Público targets auto-accept; privado targets create a
/// pending row the owner must approve (brief §5.4). Apenas-amigos visibility
/// is computed as "both directions accepted", not a distinct follow status.
model Follow {
  id          String       @id @default(cuid())
  followerId  String
  follower    User         @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  followed    User         @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  status      FollowStatus

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@unique([followerId, followingId])
  @@index([followingId, status])
  @@index([followerId, status])
}

/// Only the activity types we can actually produce today are emitted
/// (watched/want_to_watch/rating); the rest of the shared enum is reserved
/// for features landing in later milestones (Listas, referrals, Versus).
enum ActivityType {
  watched
  want_to_watch
  rating
  review
  list_created
  referral
  versus_created
  versus_voted
}

model Activity {
  id      String       @id @default(cuid())
  userId  String
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    ActivityType
  titleId String?
  title   Title?       @relation(fields: [titleId], references: [id], onDelete: Cascade)
  rating  Float?

  versusId String?
  versus   Versus? @relation(fields: [versusId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  likes    Like[]
  comments Comment[]
  notifications Notification[]

  @@index([userId, createdAt])
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, activityId])
  @@index([activityId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime @default(now())

  @@index([activityId, createdAt])
}

// ---------------------------------------------------------------------------
// Gamification — Ordem Cinéfila
// ---------------------------------------------------------------------------

enum CinephileRank {
  espectador
  apreciador
  cinetico
  cinefilo
  curador
  arquiteto
}

enum IcgAxis {
  volume
  diversidade
  profundidade
  consistencia
}

/// Cached ICG result (brief §5.5). Recomputed lazily on a cache window rather
/// than on every profile view; rankSince backs the rate-limited rank-change
/// rule (promote/demote at most one step per recompute).
model CinephileOrder {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rank   CinephileRank @default(espectador)
  icg    Float         @default(0)

  volumeScore       Float @default(0)
  diversityScore    Float @default(0)
  depthScore        Float @default(0)
  consistencyScore  Float @default(0)
  weakestAxis       IcgAxis @default(volume)

  rankSince   DateTime @default(now())
  calculatedAt DateTime @default(now())
}

enum RankingEventType {
  add
  remove
}

/// Append-only consumption ledger (brief §5.7). Each watched/unwatched action
/// emits a signed-by-type delta, enabling windowed leaderboards (semana/mês/
/// todos) and clean auditing/reversal — never mutate a counter directly.
model RankingEvent {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           RankingEventType
  minutesDelta   Int              @default(0)
  moviesDelta    Int              @default(0)
  episodesDelta  Int              @default(0)
  createdAt      DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

/// Mirrors the shared NOTIFICATION_TYPES enum. Only like/comment/new_follower/
/// follow_request/follow_accepted are actually emitted today — unlike,
/// profile_interaction and versus_vote are reserved for later milestones.
enum NotificationType {
  like
  unlike
  comment
  new_follower
  follow_request
  follow_accepted
  profile_interaction
  versus_vote
  frame_gift
}

/// One row per in-app notification. Denormalizes the comment body at creation
/// time (commentPreview) so the notification stays readable even if the
/// underlying comment is later edited or deleted — never joined live.
model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User             @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  type        NotificationType

  activityId  String?
  activity    Activity?        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  commentPreview String?

  frameId String?
  frame   Frame?  @relation(fields: [frameId], references: [id], onDelete: Cascade)

  versusId String?
  versus   Versus? @relation(fields: [versusId], references: [id], onDelete: Cascade)

  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, read])
}

/// One row per registered device. Keyed by the Expo push token itself since a
/// token belongs to one device — re-registering under a different user (e.g.
/// shared device, re-login) simply reassigns ownership.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Molduras (avatar frames)
// ---------------------------------------------------------------------------

/// Mirrors the shared FRAME_RARITIES enum.
enum FrameRarity {
  comum
  especial
  lendario
  staff
  premium
}

/// Mirrors the shared FRAME_EFFECTS enum — rendered via Reanimated on the
/// client, never GIFs/video assets.
enum FrameEffect {
  none
  glow
  pulse
  rotate
  shimmer
  orbital
  prismatic
  scanline
  aurora
}

/// How a UserFrame row was acquired.
enum FrameSource {
  starter
  rank_unlock
  founder_gift
}

/// The frame catalog. `unlockRank` gates rank-based auto-unlocks (null for the
/// starter frame and the founder-exclusive "staff" frames, which are only
/// ever granted directly). The founder account (brief: only the operator's
/// own account) is treated as owning every frame regardless of UserFrame rows
/// — see frameService.isFounder — and is the only account allowed to gift
/// staff frames to other users.
model Frame {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String
  rarity      FrameRarity
  effect      FrameEffect
  colors      String[]      @default([])
  unlockRank  CinephileRank?
  /// Non-null only for Premium-exclusive frames. Ownership is computed live
  /// from User.entitlement (like the founder bypass) — never a stored
  /// UserFrame row, since access must lapse if the subscription lapses.
  unlockEntitlement EntitlementTier?

  owners        UserFrame[]
  activeFor     User[]         @relation("ActiveFrame")
  notifications Notification[]

  createdAt DateTime @default(now())
}

/// One row per (user, frame) unlock/grant — the user's frame inventory.
model UserFrame {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("FrameOwner", fields: [userId], references: [id], onDelete: Cascade)
  frameId String
  frame   Frame @relation(fields: [frameId], references: [id], onDelete: Cascade)

  source     FrameSource
  giftedById String?
  giftedBy   User?       @relation("FrameGiftedBy", fields: [giftedById], references: [id], onDelete: SetNull)

  unlockedAt DateTime @default(now())

  @@unique([userId, frameId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Filme Versus
// ---------------------------------------------------------------------------

enum VersusChoice {
  a
  b
}

/// A head-to-head poll between two titles (brief §5.8). Visible to anyone by
/// id ("público"), but casting a vote requires having watched BOTH titles —
/// enforced at vote time, not just at creation. Closes automatically once
/// `closesAt` passes; there is no background job, `isClosed` is derived from
/// `closesAt` at read time (same lazy-compute style as CinephileOrder).
model Versus {
  id        String @id @default(cuid())
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  titleAId String
  titleA   Title  @relation("VersusTitleA", fields: [titleAId], references: [id], onDelete: Cascade)
  titleBId String
  titleB   Title  @relation("VersusTitleB", fields: [titleBId], references: [id], onDelete: Cascade)

  question String?
  closesAt DateTime

  votes         VersusVote[]
  activities    Activity[]
  notifications Notification[]

  createdAt DateTime @default(now())

  @@index([creatorId, createdAt])
}

/// One vote per (versus, user) — final, never overwritten (brief: no vote changes).
model VersusVote {
  id       String       @id @default(cuid())
  versusId String
  versus   Versus       @relation(fields: [versusId], references: [id], onDelete: Cascade)
  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice   VersusChoice

  createdAt DateTime @default(now())

  @@unique([versusId, userId])
  @@index([versusId])
}

// ---------------------------------------------------------------------------
// Premium (RevenueCat)
// ---------------------------------------------------------------------------

enum EntitlementTier {
  free
  premium
}

/// Cached current subscription state (one per user) — mirrors the latest
/// RevenueCat webhook/client sync, same cache-vs-ledger split as
/// CinephileOrder/RankingEvent. `tier` can lag User.entitlement by nothing
/// (they're written together); kept as its own model since it carries fields
/// (productId/store/willRenew) that don't belong on User.
model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier      EntitlementTier @default(free)
  productId String
  store     String
  willRenew Boolean         @default(false)
  expiresAt DateTime?

  updatedAt DateTime @updatedAt
}

/// Append-only ledger of processed RevenueCat webhook deliveries. `rcEventId`
/// (RevenueCat's own event.id) is unique so redelivered webhooks — RevenueCat
/// retries on any non-2xx — are detected and ignored instead of re-applied.
model RevenueCatEvent {
  id          String   @id @default(cuid())
  rcEventId   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  productId   String?
  store       String?
  environment String
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}
